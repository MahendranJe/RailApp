@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="row justify-content-center">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body p-5">
                <h1 class="mb-4">@ViewData["Title"]</h1>
                
                <p class="lead">Your privacy is important to us. This policy explains how Train Updates collects, uses, and protects your personal information.</p>

                <h4 class="mt-4">Information We Collect</h4>
                <p>We collect information you provide directly to us, such as:</p>
                <ul>
                    <li>Account information (name, email)</li>
                    <li>Train alert preferences</li>
                    <li>Subscription details</li>
                </ul>

                <h4 class="mt-4">How We Use Your Information</h4>
                <p>We use the information we collect to:</p>
                <ul>
                    <li>Provide, maintain, and improve our services</li>
                    <li>Send you train updates and availability notifications</li>
                    <li>Process transactions and subscriptions</li>
                    <li>Send you technical notices and support messages</li>
                </ul>

                <h4 class="mt-4">Data Security</h4>
                <p>We take reasonable measures to help protect information about you from loss, theft, misuse, and unauthorized access.</p>

                <h4 class="mt-4">Contact Us</h4>
                <p>If you have any questions about this Privacy Policy, please contact us at:</p>
                <p><strong>Email:</strong> support@trainupdates.com</p>

                <p class="text-muted mt-4"><small>Last updated: @DateTime.Now.ToString("MMMM dd, yyyy")</small></p>
            </div>
        </div>
    </div>
</div>
