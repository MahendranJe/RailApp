@model List<Alert>
@{
    ViewData["Title"] = "My Alerts";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h2><i class="bi bi-bell-fill me-2"></i>My Alerts</h2>
        <p class="text-muted mb-0">Track ticket availability for your trains</p>
    </div>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-plus-lg me-2"></i>Create Alert
    </a>
</div>

@if (Model.Any())
{
    <div class="row">
        @foreach (var alert in Model)
        {
            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100 @(alert.IsAvailable ? "border-success" : (alert.TravelDate < DateTime.Today ? "border-secondary" : ""))">
                    <div class="card-header bg-transparent d-flex justify-content-between align-items-center">
                        <span class="badge bg-primary fs-6">@alert.TrainNumber</span>
                        @if (alert.IsAvailable)
                        {
                            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Available</span>
                        }
                        else if (alert.TravelDate < DateTime.Today)
                        {
                            <span class="badge bg-secondary">Expired</span>
                        }
                        else
                        {
                            <span class="badge bg-warning text-dark"><i class="bi bi-clock me-1"></i>Pending</span>
                        }
                    </div>
                    <div class="card-body">
                        <div class="mb-3">
                            <div class="d-flex align-items-center text-primary mb-1">
                                <i class="bi bi-geo-alt me-2"></i>
                                <span>@(alert.FromStation ?? "Any")</span>
                            </div>
                            <div class="d-flex align-items-center text-success">
                                <i class="bi bi-geo-alt-fill me-2"></i>
                                <span>@(alert.ToStation ?? "Any")</span>
                            </div>
                        </div>
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div>
                                <i class="bi bi-calendar3 me-2 text-muted"></i>
                                <span class="fw-semibold">@alert.TravelDate.ToString("dd MMM yyyy")</span>
                            </div>
                        </div>
                        <div class="small text-muted">
                            <i class="bi bi-clock me-1"></i>Created: @alert.CreatedAt.ToString("dd MMM, HH:mm")
                        </div>
                        @if (alert.NotifiedAt.HasValue)
                        {
                            <div class="small text-success mt-1">
                                <i class="bi bi-check-circle me-1"></i>Notified: @alert.NotifiedAt.Value.ToString("dd MMM, HH:mm")
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-transparent">
                        <form asp-action="Delete" asp-route-id="@alert.Id" method="post" 
                              onsubmit="return confirm('Are you sure you want to delete this alert?');">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-outline-danger btn-sm w-100">
                                <i class="bi bi-trash me-2"></i>Delete Alert
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        }
    </div>
}
else
{
    <div class="card">
        <div class="card-body text-center py-5">
            <i class="bi bi-bell-slash fs-1 text-muted mb-3"></i>
            <h5 class="text-muted">No alerts yet</h5>
            <p class="text-muted">Create an alert to get notified when tickets become available.</p>
            <a asp-action="Create" class="btn btn-primary">
                <i class="bi bi-plus-lg me-2"></i>Create Your First Alert
            </a>
        </div>
    </div>
}

<!-- Info Card -->
<div class="card mt-4 bg-light">
    <div class="card-body">
        <h6><i class="bi bi-info-circle me-2 text-info"></i>How Alerts Work</h6>
        <ul class="mb-0 small">
            <li>Create an alert for your desired train and travel date</li>
            <li>Our system checks ticket availability periodically</li>
            <li>You'll receive a notification when tickets become available</li>
            <li>Premium users get earlier notifications</li>
        </ul>
    </div>
</div>
