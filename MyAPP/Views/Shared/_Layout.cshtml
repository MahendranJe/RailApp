@using Microsoft.AspNetCore.Identity
@inject SignInManager<MyAPP.Models.ApplicationUser> SignInManager
@inject UserManager<MyAPP.Models.ApplicationUser> UserManager

<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Southzone Railway Update</title>
    <link rel="icon" type="image/png" href="~/images/logo.png" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" />
    <style>
        :root {
            --gradient-start: #667eea;
            --gradient-end: #764ba2;
        }

        html,
        body {
            height: 100%;
            margin: 0;
            padding: 0;
            overflow-x: hidden;
        }

        body {
            display: flex;
            flex-direction: column;
            min-height: 100vh;
            background-color: #f8f9fa;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }

        .navbar-brand {
            font-weight: 700;
            font-size: 1.3rem;
        }

        .navbar-brand img {
            height: 40px;
            width: 40px;
            object-fit: contain;
            margin-right: 10px;
        }

        .hero-gradient {
            background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
        }

        /* Main scrollable content */
        .main-wrapper {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
        }

        .card {
            border: none;
            border-radius: 12px;
            box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
            transition: transform 0.2s, box-shadow 0.2s;
        }

        .card:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.12);
        }

        .btn-primary {
            background: linear-gradient(135deg, var(--gradient-start) 0%, var(--gradient-end) 100%);
            border: none;
        }

        .btn-primary:hover {
            background: linear-gradient(135deg, #5a6fd6 0%, #6a4190 100%);
        }

        /* Notification Dropdown */
        .dropdown-notifications {
            width: 320px;
            max-height: 400px;
            overflow: hidden;
            border: none;
            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
        }

        .notification-badge {
            position: absolute;
            top: 2px;
            right: 2px;
            padding: 2px 6px;
            border-radius: 10px;
            background: #dc3545;
            color: white;
            font-size: 0.65rem;
            font-weight: bold;
            min-width: 18px;
            text-align: center;
        }

        .notification-item {
            transition: background-color 0.2s;
            cursor: pointer;
        }

        .notification-item:hover {
            background-color: #f8f9fa;
        }

        .notification-item.unread {
            background-color: #e8f4fd;
            border-left: 3px solid #0d6efd;
        }

        .notification-item.unread:hover {
            background-color: #d6ebfa;
        }

        .tatkal-timer {
            background: linear-gradient(135deg, #ff416c 0%, #ff4b2b 100%);
            color: white;
            padding: 15px;
            border-radius: 12px;
            text-align: center;
        }

        /* User Profile Avatar */
        .user-avatar {
            width: 35px;
            height: 35px;
            border-radius: 50%;
            object-fit: cover;
            border: 2px solid #fff;
        }

        /* Small Fixed Footer */
        .site-footer {
            flex-shrink: 0;
            background-color: #343a40;
            color: #adb5bd;
            padding: 15px 0;
            font-size: 0.85rem;
        }

        .site-footer a {
            color: #adb5bd;
            text-decoration: none;
            margin: 0 8px;
            transition: color 0.3s;
        }

        .site-footer a:hover {
            color: white;
        }

        .social-links a {
            font-size: 1.2rem;
            margin: 0 10px;
            display: inline-block;
            transition: transform 0.3s;
        }

        .social-links a:hover {
            transform: scale(1.2);
        }

        /* Custom scrollbar */
        ::-webkit-scrollbar {
            width: 6px;
        }

        ::-webkit-scrollbar-track {
            background: #f1f1f1;
        }

        ::-webkit-scrollbar-thumb {
            background: #c1c1c1;
            border-radius: 3px;
        }

        ::-webkit-scrollbar-thumb:hover {
            background: #a1a1a1;
        }
    </style>
</head>

<body>
    <!-- Fixed Navbar -->
    <nav class="navbar navbar-expand-lg navbar-dark hero-gradient shadow-sm">
        <div class="container">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                @* Train icon as placeholder until logo.png is added to wwwroot/images/ *@
                <i class="bi bi-train-freight-front-fill" style="font-size: 1.8rem; margin-right: 10px;"></i>
                Southzone Railway Update
            </a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-fill me-1"></i>Home
                        </a>
                    </li>
                    @if (SignInManager.IsSignedIn(User))
                    {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Alerts" asp-action="Index">
                            <i class="bi bi-bell-fill me-1"></i>Alerts
                        </a>
                    </li>
                    @if (User.IsInRole("Admin"))
                    {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Admin" asp-action="Dashboard">
                            <i class="bi bi-speedometer2 me-1"></i>Admin
                        </a>
                    </li>
                    }
                    }
                </ul>
                <ul class="navbar-nav">
                    @if (SignInManager.IsSignedIn(User))
                    {
                    var currentUser = await UserManager.GetUserAsync(User);
                    <li class="nav-item dropdown me-2">
                        <a class="nav-link position-relative" href="#" id="notificationDropdown" role="button" 
                           data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false">
                            <i class="bi bi-bell-fill"></i>
                            <span class="notification-badge" id="notificationCount" style="display:none;">0</span>
                        </a>
                        <div class="dropdown-menu dropdown-menu-end dropdown-notifications p-0" aria-labelledby="notificationDropdown">
                            <div class="p-2 border-bottom d-flex justify-content-between align-items-center bg-light">
                                <small class="fw-bold"><i class="bi bi-bell me-1"></i>Notifications</small>
                                <a href="@Url.Action("Index", "Notifications")" class="small text-primary text-decoration-none">
                                    View All <i class="bi bi-arrow-right"></i>
                                </a>
                            </div>
                            <div id="notificationList" style="max-height: 300px; overflow-y: auto;">
                                <div class="p-3 text-center text-muted small">
                                    <i class="bi bi-hourglass-split me-1"></i>Loading...
                                </div>
                            </div>
                        </div>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle d-flex align-items-center" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown">
                            @* User avatar - shows user initials *@
                            <div class="user-avatar me-2 d-flex align-items-center justify-content-center bg-primary text-white" style="font-weight: bold;">
                                @currentUser?.FullName.Substring(0, 1).ToUpper()
                            </div>
                            <span class="d-none d-md-inline">@currentUser?.FullName</span>
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end">
                            <li><span class="dropdown-item-text small text-muted">@currentUser?.Email</span></li>
                            <li><span class="dropdown-item-text small text-muted">@@@currentUser?.UserName</span></li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item small text-danger"><i
                                            class="bi bi-box-arrow-right me-2"></i>Logout</button>
                                </form>
                            </li>
                        </ul>
                    </li>
                    }
                    else
                    {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Account" asp-action="Login">
                            <i class="bi bi-box-arrow-in-right me-1"></i>Login
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="btn btn-light btn-sm ms-2" asp-controller="Account" asp-action="Register">
                            <i class="bi bi-person-plus me-1"></i>Register
                        </a>
                    </li>
                    }
                </ul>
            </div>
        </div>
    </nav>

    <!-- Main Scrollable Content -->
    <div class="main-wrapper">
        <div class="container py-3">
            @if (TempData["SuccessMessage"] != null)
            {
            <div class="alert alert-success alert-dismissible fade show py-2 small" role="alert">
                <i class="bi bi-check-circle-fill me-2"></i>@TempData["SuccessMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            }
            @if (TempData["ErrorMessage"] != null)
            {
            <div class="alert alert-danger alert-dismissible fade show py-2 small" role="alert">
                <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["ErrorMessage"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
            }
            @RenderBody()
        </div>
    </div>

    <!-- Small Fixed Footer -->
    <footer class="site-footer">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-4 text-center text-md-start mb-2 mb-md-0">
                    <span>&copy; 2025 Southzone Railway Update</span>
                </div>
                <div class="col-md-4 text-center mb-2 mb-md-0">
                    <a asp-controller="Home" asp-action="Index">Home</a>
                    <a asp-controller="Home" asp-action="Privacy">Privacy</a>
                </div>
                <div class="col-md-4 text-center text-md-end social-links">
                    <a href="https://whatsapp.com/channel/0029Va6gl6EFcow4AOH5UC3i" target="_blank" title="WhatsApp Channel">
                        <i class="bi bi-whatsapp text-success"></i>
                    </a>
                    <a href="https://www.instagram.com/southzone_railwayupdate" target="_blank" title="Instagram">
                        <i class="bi bi-instagram text-danger"></i>
                    </a>
                </div>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (SignInManager.IsSignedIn(User))
    {
        <script>
            // Notification polling
            function loadNotifications() {
                $.get('@Url.Action("GetUnreadNotifications", "Notifications")', function (data) {
                    if (data && data.length > 0) {
                        $('#notificationCount').text(data.length).show();
                        var html = '';
                        data.forEach(function (notification) {
                            html += '<div class="notification-item p-3 border-bottom unread" data-id="' + notification.id + '">';
                            html += '<div class="d-flex justify-content-between align-items-start">';
                            html += '<div class="flex-grow-1">';
                            html += '<h6 class="mb-1 small fw-bold">' + notification.title + '</h6>';
                            html += '<p class="mb-1 small text-muted">' + notification.message + '</p>';
                            html += '<small class="text-muted"><i class="bi bi-clock me-1"></i>' + new Date(notification.createdAt).toLocaleString() + '</small>';
                            html += '</div>';
                            html += '</div>';
                            html += '</div>';
                        });
                        $('#notificationList').html(html);
                    } else {
                        $('#notificationCount').hide();
                        $('#notificationList').html('<div class="p-3 text-center text-muted small"><i class="bi bi-inbox me-1"></i>No new notifications</div>');
                    }
                });
            }

            // Load notifications on page load
            loadNotifications();

            // Poll every 30 seconds
            setInterval(loadNotifications, 30000);

            // Mark as read on click
            $(document).on('click', '.notification-item', function () {
                var id = $(this).data('id');
                $.post('@Url.Action("MarkAsRead", "Notifications")', { id: id }, function () {
                    loadNotifications();
                });
            });
        </script>
    }

    <!-- Tatkal Timer Script -->
    <script>
        function updateTatkalTimers() {
            const now = new Date();
            const acTime = new Date();
            acTime.setHours(10, 0, 0, 0);
            const nonAcTime = new Date();
            nonAcTime.setHours(11, 0, 0, 0);

            if (now > acTime) acTime.setDate(acTime.getDate() + 1);
            if (now > nonAcTime) nonAcTime.setDate(nonAcTime.getDate() + 1);

            function formatTime(diff) {
                const hours = Math.floor(diff / (1000 * 60 * 60));
                const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
                const seconds = Math.floor((diff % (1000 * 60)) / 1000);
                return `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
            }

            const acDiff = acTime - now;
            const nonAcDiff = nonAcTime - now;

            const acTimer = document.getElementById('acTimer');
            const nonAcTimer = document.getElementById('nonAcTimer');

            if (acTimer) acTimer.textContent = formatTime(acDiff);
            if (nonAcTimer) nonAcTimer.textContent = formatTime(nonAcDiff);
        }

        updateTatkalTimers();
        setInterval(updateTatkalTimers, 1000);
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>
