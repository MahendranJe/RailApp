@model List<Alert>
@{
    ViewData["Title"] = "Manage Alerts";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h2><i class="bi bi-bell-fill me-2"></i>Manage Alerts</h2>
        <p class="text-muted mb-0">View and manage user alerts, or create broadcast alerts</p>
    </div>
    <a asp-action="CreateBroadcastAlert" class="btn btn-primary">
        <i class="bi bi-megaphone me-2"></i>Create Broadcast Alert
    </a>
</div>

<!-- Stats -->
<div class="row g-3 mb-4">
    <div class="col-6 col-md-3">
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <h3 class="mb-0">@Model.Count</h3>
                <small>Total Alerts</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card bg-warning text-dark">
            <div class="card-body text-center">
                <h3 class="mb-0">@Model.Count(a => !a.IsNotified && !a.IsBroadcast)</h3>
                <small>Pending</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h3 class="mb-0">@Model.Count(a => a.IsAvailable)</h3>
                <small>Available</small>
            </div>
        </div>
    </div>
    <div class="col-6 col-md-3">
        <div class="card bg-info text-white">
            <div class="card-body text-center">
                <h3 class="mb-0">@Model.Count(a => a.IsBroadcast)</h3>
                <small>Broadcasts</small>
            </div>
        </div>
    </div>
</div>

<!-- Alerts Table -->
<div class="card">
    <div class="card-header bg-transparent">
        <ul class="nav nav-tabs card-header-tabs" id="alertTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="user-alerts-tab" data-bs-toggle="tab" data-bs-target="#user-alerts" type="button">
                    <i class="bi bi-person me-1"></i>User Alerts (@Model.Count(a => !a.IsBroadcast))
                </button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="broadcast-alerts-tab" data-bs-toggle="tab" data-bs-target="#broadcast-alerts" type="button">
                    <i class="bi bi-megaphone me-1"></i>Broadcast Alerts (@Model.Count(a => a.IsBroadcast))
                </button>
            </li>
        </ul>
    </div>
    <div class="card-body">
        <div class="tab-content" id="alertTabsContent">
            <!-- User Alerts Tab -->
            <div class="tab-pane fade show active" id="user-alerts" role="tabpanel">
                @{
                    var userAlerts = Model.Where(a => !a.IsBroadcast).ToList();
                }
                @if (userAlerts.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>User</th>
                                    <th>Train</th>
                                    <th>Route</th>
                                    <th>Travel Date</th>
                                    <th>Status</th>
                                    <th>Created</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var alert in userAlerts)
                                {
                                    <tr>
                                        <td>
                                            <div class="d-flex align-items-center">
                                                <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2" style="width: 35px; height: 35px;">
                                                    <i class="bi bi-person-fill"></i>
                                                </div>
                                                <div>
                                                    <div class="fw-semibold">@(alert.User?.FullName ?? "Unknown")</div>
                                                    <small class="text-muted">@(alert.User?.Email ?? "")</small>
                                                </div>
                                            </div>
                                        </td>
                                        <td>
                                            <span class="badge bg-primary fs-6">@alert.TrainNumber</span>
                                        </td>
                                        <td>
                                            <span class="text-primary">@(alert.FromStation ?? "Any")</span>
                                            <i class="bi bi-arrow-right mx-1"></i>
                                            <span class="text-success">@(alert.ToStation ?? "Any")</span>
                                        </td>
                                        <td>
                                            <i class="bi bi-calendar3 me-1"></i>
                                            @alert.TravelDate.ToString("dd MMM yyyy")
                                            @if (alert.TravelDate < DateTime.Today)
                                            {
                                                <span class="badge bg-secondary ms-1">Expired</span>
                                            }
                                        </td>
                                        <td>
                                            @if (alert.IsAvailable)
                                            {
                                                <span class="badge bg-success">
                                                    <i class="bi bi-check-circle me-1"></i>Available
                                                </span>
                                            }
                                            else if (alert.IsNotified)
                                            {
                                                <span class="badge bg-info">
                                                    <i class="bi bi-bell me-1"></i>Notified
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    <i class="bi bi-clock me-1"></i>Pending
                                                </span>
                                            }
                                        </td>
                                        <td>
                                            <small class="text-muted">@alert.CreatedAt.ToString("dd MMM, HH:mm")</small>
                                        </td>
                                        <td class="text-end">
                                            @if (!alert.IsAvailable && !alert.IsNotified && alert.TravelDate >= DateTime.Today)
                                            {
                                                <form asp-action="MarkAlertAvailable" asp-route-id="@alert.Id" method="post" class="d-inline">
                                                    @Html.AntiForgeryToken()
                                                    <button type="submit" class="btn btn-success btn-sm" title="Mark as Available">
                                                        <i class="bi bi-check-lg"></i> Mark Available
                                                    </button>
                                                </form>
                                            }
                                            <form asp-action="DeleteAlert" asp-route-id="@alert.Id" method="post" class="d-inline"
                                                  onsubmit="return confirm('Are you sure you want to delete this alert?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-outline-danger btn-sm" title="Delete Alert">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-bell-slash fs-1 mb-3"></i>
                        <p>No user alerts found.</p>
                    </div>
                }
            </div>

            <!-- Broadcast Alerts Tab -->
            <div class="tab-pane fade" id="broadcast-alerts" role="tabpanel">
                @{
                    var broadcastAlerts = Model.Where(a => a.IsBroadcast).ToList();
                }
                @if (broadcastAlerts.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-hover align-middle">
                            <thead class="table-light">
                                <tr>
                                    <th>Train</th>
                                    <th>Route</th>
                                    <th>Travel Date</th>
                                    <th>Message</th>
                                    <th>Created By</th>
                                    <th>Created At</th>
                                    <th class="text-end">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var alert in broadcastAlerts)
                                {
                                    <tr>
                                        <td>
                                            <span class="badge bg-info fs-6">
                                                <i class="bi bi-megaphone me-1"></i>@alert.TrainNumber
                                            </span>
                                        </td>
                                        <td>
                                            <span class="text-primary">@(alert.FromStation ?? "Any")</span>
                                            <i class="bi bi-arrow-right mx-1"></i>
                                            <span class="text-success">@(alert.ToStation ?? "Any")</span>
                                        </td>
                                        <td>
                                            <i class="bi bi-calendar3 me-1"></i>
                                            @alert.TravelDate.ToString("dd MMM yyyy")
                                        </td>
                                        <td>
                                            <small class="text-muted">@(alert.Message ?? "No message")</small>
                                        </td>
                                        <td>
                                            <small>@(alert.CreatedBy?.FullName ?? "Admin")</small>
                                        </td>
                                        <td>
                                            <small class="text-muted">@alert.CreatedAt.ToString("dd MMM, HH:mm")</small>
                                        </td>
                                        <td class="text-end">
                                            <form asp-action="DeleteAlert" asp-route-id="@alert.Id" method="post" class="d-inline"
                                                  onsubmit="return confirm('Are you sure you want to delete this broadcast alert?');">
                                                @Html.AntiForgeryToken()
                                                <button type="submit" class="btn btn-outline-danger btn-sm" title="Delete">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            </form>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center py-5 text-muted">
                        <i class="bi bi-megaphone fs-1 mb-3"></i>
                        <p>No broadcast alerts created yet.</p>
                        <a asp-action="CreateBroadcastAlert" class="btn btn-primary">
                            <i class="bi bi-plus-lg me-2"></i>Create Broadcast Alert
                        </a>
                    </div>
                }
            </div>
        </div>
    </div>
</div>
