@model List<(MyAPP.Models.ApplicationUser User, IList<string> Roles, MyAPP.Models.Subscription? Subscription)>

@{
    ViewData["Title"] = "Manage Users";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h2><i class="bi bi-people me-2"></i>All Users</h2>
        <p class="text-muted mb-0">Manage registered users (@Model.Count total)</p>
    </div>
    <a asp-action="Dashboard" class="btn btn-outline-secondary">
        <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive" style="max-height: 70vh; overflow-y: auto;">
                <table class="table table-hover mb-0">
                    <thead class="table-light" style="position: sticky; top: 0; z-index: 1;">
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Phone</th>
                            <th>Gender</th>
                            <th>State</th>
                            <th>City</th>
                            <th>Username</th>
                            <th>Role</th>
                            <th>Subscription</th>
                            <th>Joined</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td>
                                    <div class="d-flex align-items-center">
                                        <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center me-2 flex-shrink-0" style="width: 35px; height: 35px;">
                                            @item.User.FullName.Substring(0, 1).ToUpper()
                                        </div>
                                        <span class="text-truncate" style="max-width: 120px;" title="@item.User.FullName">@item.User.FullName</span>
                                    </div>
                                </td>
                                <td class="text-truncate" style="max-width: 160px;" title="@item.User.Email">@item.User.Email</td>
                                <td class="text-nowrap">
                                    @if (!string.IsNullOrEmpty(item.User.PhoneNumber))
                                    {
                                        <span>@item.User.PhoneNumber</span>
                                    }
                                    else if (!string.IsNullOrEmpty(item.User.MobileNumber))
                                    {
                                        <span>@item.User.MobileNumber</span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(item.User.Gender))
                                    {
                                        <span class="badge @(item.User.Gender == "Male" ? "bg-info" : item.User.Gender == "Female" ? "bg-pink" : "bg-secondary")" 
                                              style="@(item.User.Gender == "Female" ? "background-color: #e83e8c !important;" : "")">
                                            @item.User.Gender
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="text-muted">N/A</span>
                                    }
                                </td>
                                <td class="text-truncate" style="max-width: 100px;" title="@item.User.State">
                                    @(string.IsNullOrEmpty(item.User.State) ? "-" : item.User.State)
                                </td>
                                <td class="text-truncate" style="max-width: 100px;" title="@item.User.City">
                                    @(string.IsNullOrEmpty(item.User.City) ? "-" : item.User.City)
                                </td>
                                <td class="text-truncate" style="max-width: 100px;" title="@item.User.UserName">
                                    <code>@item.User.UserName</code>
                                </td>
                                <td>
                                    @foreach (var role in item.Roles)
                                    {
                                        <span class="badge @(role == "Admin" ? "bg-danger" : "bg-primary")">@role</span>
                                    }
                                </td>
                                <td>
                                    @if (item.Subscription != null)
                                    {
                                        <span class="badge @(item.Subscription.PlanName == "Premium" ? "bg-warning text-dark" : item.Subscription.PlanName == "Monthly" ? "bg-info" : "bg-secondary")">
                                            @item.Subscription.PlanName
                                        </span>
                                        @if (item.Subscription.ExpiryDate.HasValue)
                                        {
                                            <small class="text-muted d-block text-nowrap">Exp: @item.Subscription.ExpiryDate.Value.ToString("dd MMM yy")</small>
                                        }
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Free</span>
                                    }
                                </td>
                                <td class="text-nowrap">@item.User.CreatedAt.ToString("dd MMM yyyy")</td>
                                <td>
                                    @if (item.User.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Inactive</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-people fs-1 text-muted"></i>
                <p class="text-muted mt-2">No users registered yet</p>
            </div>
        }
    </div>
</div>

<!-- Summary Cards -->
<div class="row mt-4">
    <div class="col-md-3 mb-3">
        <div class="card bg-primary text-white">
            <div class="card-body text-center">
                <h4>@Model.Count</h4>
                <p class="mb-0">Total Users</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card bg-danger text-white">
            <div class="card-body text-center">
                <h4>@Model.Count(u => u.Roles.Contains("Admin"))</h4>
                <p class="mb-0">Admins</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card bg-success text-white">
            <div class="card-body text-center">
                <h4>@Model.Count(u => u.User.IsActive)</h4>
                <p class="mb-0">Active Users</p>
            </div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="card bg-info text-white">
            <div class="card-body text-center">
                <h4>@Model.Count(u => u.Subscription != null && u.Subscription.PlanName != "Free")</h4>
                <p class="mb-0">Premium Users</p>
            </div>
        </div>
    </div>
</div>
