@model List<MyAPP.Models.TrainUpdate>
@{
    ViewData["Title"] = "Manage Train Updates";
    var scheduleInfo = ViewBag.ScheduleInfo as Dictionary<int, (string DisplayText, string BadgeClass, string BadgeText, string? NextRun)> 
        ?? new Dictionary<int, (string DisplayText, string BadgeClass, string BadgeText, string? NextRun)>();
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h2><i class="bi bi-newspaper me-2"></i>Train Updates</h2>
        <p class="text-muted mb-0">Manage all train updates (@Model.Count total)</p>
    </div>
    <div class="d-flex gap-2 flex-wrap">
        <a asp-action="Dashboard" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i>Dashboard
        </a>
        <a asp-action="CreateTrainUpdate" class="btn btn-primary">
            <i class="bi bi-plus-lg me-2"></i>Add New
        </a>
    </div>
</div>

<!-- Schedule Type Legend -->
<div class="card mb-3">
    <div class="card-body py-2">
        <small class="text-muted me-2">Schedule Types:</small>
        <span class="badge bg-success me-1">Daily</span>
        <span class="badge bg-primary me-1">Weekly</span>
        <span class="badge bg-warning text-dark me-1">Custom</span>
        <span class="badge bg-danger me-1">One-Time</span>
        <span class="badge bg-info me-1">Date Range</span>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive" style="max-height: 70vh; overflow-y: auto;">
                <table class="table table-hover mb-0">
                    <thead class="table-light" style="position: sticky; top: 0; z-index: 1;">
                        <tr>
                            <th style="width: 50px;">ID</th>
                            <th style="width: 80px;">Train No</th>
                            <th>Title</th>
                            <th>Route</th>
                            <th style="width: 150px;">Schedule</th>
                            <th style="width: 100px;">Next Run</th>
                            <th style="width: 60px;">Image</th>
                            <th style="width: 90px;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var update in Model)
                        {
                            var hasInfo = scheduleInfo.TryGetValue(update.Id, out var info);
                            <tr>
                                <td>@update.Id</td>
                                <td><span class="badge bg-primary">@update.TrainNumber</span></td>
                                <td>
                                    <div class="fw-semibold text-truncate" style="max-width: 200px;">@update.Title</div>
                                    <small class="text-muted text-truncate d-block" style="max-width: 250px;">
                                        @(update.Description.Length > 50 ? update.Description.Substring(0, 50) + "..." : update.Description)
                                    </small>
                                </td>
                                <td>
                                    <small class="text-truncate d-block" style="max-width: 150px;">
                                        <i class="bi bi-geo-alt text-primary me-1"></i>@update.FromStation
                                        <i class="bi bi-arrow-right mx-1"></i>
                                        <i class="bi bi-geo-alt-fill text-success me-1"></i>@update.ToStation
                                    </small>
                                </td>
                                <td>
                                    @if (hasInfo)
                                    {
                                        <span class="badge @info.BadgeClass mb-1">@info.BadgeText</span>
                                        <small class="d-block text-muted" style="font-size: 0.7rem;">@info.DisplayText</small>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Unknown</span>
                                    }
                                </td>
                                <td class="text-nowrap">
                                    @if (hasInfo && !string.IsNullOrEmpty(info.NextRun))
                                    {
                                        <small class="text-success">
                                            <i class="bi bi-calendar-check me-1"></i>@info.NextRun
                                        </small>
                                    }
                                    else
                                    {
                                        <small class="text-muted">
                                            <i class="bi bi-calendar-x me-1"></i>N/A
                                        </small>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(update.ImagePath))
                                    {
                                        <img src="@update.ImagePath" alt="Timetable" class="img-thumbnail" style="max-height: 40px; max-width: 50px;">
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </td>
                                <td>
                                    <div class="btn-group btn-group-sm">
                                        <a asp-action="EditTrainUpdate" asp-route-id="@update.Id" class="btn btn-outline-primary" title="Edit">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <form asp-action="DeleteTrainUpdate" asp-route-id="@update.Id" method="post" class="d-inline" 
                                              onsubmit="return confirm('Are you sure you want to delete this update?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-outline-danger" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted"></i>
                <p class="text-muted mt-2">No train updates yet</p>
                <a asp-action="CreateTrainUpdate" class="btn btn-primary">
                    <i class="bi bi-plus-lg me-2"></i>Add First Update
                </a>
            </div>
        }
    </div>
</div>
