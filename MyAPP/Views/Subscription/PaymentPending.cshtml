@model PaymentConfirmationViewModel
@{
    ViewData["Title"] = "Payment Submitted";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm text-center">
            <div class="card-body p-4">
                <div class="mb-4">
                    <div class="bg-warning text-dark rounded-circle d-inline-flex align-items-center justify-content-center" style="width: 80px; height: 80px;">
                        <i class="bi bi-hourglass-split fs-1"></i>
                    </div>
                </div>

                <h3 class="text-warning mb-2">Payment Submitted!</h3>
                <p class="text-muted mb-4">Your payment is pending verification by admin.</p>

                <div class="bg-light p-3 rounded mb-4 text-start">
                    <div class="row">
                        <div class="col-6 mb-2">
                            <small class="text-muted">Transaction ID</small>
                            <div class="fw-bold"><code>@Model.TransactionId</code></div>
                        </div>
                        <div class="col-6 mb-2">
                            <small class="text-muted">Amount</small>
                            <div class="fw-bold text-success fs-5">?@Model.Amount</div>
                        </div>
                        <div class="col-6 mb-2">
                            <small class="text-muted">Plan</small>
                            <div class="fw-bold">@Model.PlanName</div>
                        </div>
                        <div class="col-6 mb-2">
                            <small class="text-muted">Payment App</small>
                            <div class="fw-bold"><i class="bi bi-phone me-1"></i>@Model.PaymentMethod</div>
                        </div>
                        <div class="col-6 mb-2">
                            <small class="text-muted">Your UPI ID</small>
                            <div class="fw-bold">@Model.UpiId</div>
                        </div>
                        <div class="col-6 mb-2">
                            <small class="text-muted">UTR / Reference</small>
                            <div class="fw-bold text-primary">@Model.UtrNumber</div>
                        </div>
                        <div class="col-12">
                            <small class="text-muted">Status</small>
                            <div><span class="badge bg-warning text-dark fs-6"><i class="bi bi-clock me-1"></i>Pending Verification</span></div>
                        </div>
                    </div>
                </div>

                <div class="alert alert-info text-start mb-4">
                    <h6 class="alert-heading"><i class="bi bi-info-circle me-2"></i>What happens next?</h6>
                    <ul class="small mb-0">
                        <li>Admin will verify your payment</li>
                        <li>This usually takes <strong>5-30 minutes</strong></li>
                        <li>You'll get a <strong>notification</strong> when approved</li>
                        <li>Your subscription will be activated automatically</li>
                    </ul>
                </div>

                <div class="d-flex gap-2 justify-content-center flex-wrap">
                    <a asp-controller="Home" asp-action="Index" class="btn btn-primary">
                        <i class="bi bi-house me-2"></i>Go Home
                    </a>
                    <a asp-action="History" class="btn btn-outline-secondary">
                        <i class="bi bi-receipt me-2"></i>Check Status
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
