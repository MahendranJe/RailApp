@model List<MyAPP.Models.Payment>
@{
    ViewData["Title"] = "Payment History";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
    <div>
        <h2><i class="bi bi-receipt me-2"></i>Payment History</h2>
        <p class="text-muted mb-0">Your UPI payment records</p>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="bi bi-arrow-left me-2"></i>Back to Plans
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Transaction ID</th>
                            <th>Plan</th>
                            <th>Amount</th>
                            <th>Payment Method</th>
                            <th>UPI ID</th>
                            <th>Date</th>
                            <th>Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var payment in Model)
                        {
                            <tr>
                                <td><code class="small">@payment.TransactionId</code></td>
                                <td>
                                    <span class="badge @(payment.PlanName == "Premium" ? "bg-warning text-dark" : "bg-info")">
                                        @payment.PlanName
                                    </span>
                                </td>
                                <td><span class="fw-bold text-success">?@payment.Amount</span></td>
                                <td>
                                    <i class="bi bi-phone me-1"></i>@payment.PaymentMethod
                                </td>
                                <td class="small">@(payment.PayerUpiId ?? "-")</td>
                                <td class="small text-nowrap">@payment.PaymentDate.ToString("dd MMM yyyy, HH:mm")</td>
                                <td>
                                    @if (payment.Status == "Completed")
                                    {
                                        <span class="badge bg-success">
                                            <i class="bi bi-check-circle me-1"></i>Completed
                                        </span>
                                    }
                                    else if (payment.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark">
                                            <i class="bi bi-clock me-1"></i>Pending
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">
                                            <i class="bi bi-x-circle me-1"></i>Failed
                                        </span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="text-center py-5">
                <i class="bi bi-receipt fs-1 text-muted mb-3"></i>
                <h5 class="text-muted">No payment history</h5>
                <p class="text-muted">Your UPI payment records will appear here once you subscribe.</p>
                <a asp-action="Index" class="btn btn-primary">
                    <i class="bi bi-star me-2"></i>View Subscription Plans
                </a>
            </div>
        }
    </div>
</div>
